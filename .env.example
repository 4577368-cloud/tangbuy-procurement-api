# 本地 LLM（OpenAI 兼容接口）
LLM_MODEL_BASE_URL=http://106.75.1.42:9017/v1
LLM_MODEL_API_KEY=your-api-key
LLM_MODEL_MODEL_ID=Qwen3.5-27B

# 1688 寻源 Skill CLI
SKILL_1688_SOURCING_CLI=/Users/you/.cursor/skills/1688-sourcing-inquiry/cli.py

# 1688 商家询盘 Skill（inquiry-1688 / AlphaShop API）
SKILL_INQUIRY_1688_SCRIPT=/Users/you/.cursor/skills/inquiry-1688/scripts/inquiry.py
ALPHASHOP_ACCESS_KEY=your-access-key
ALPHASHOP_SECRET_KEY=your-secret-key

# 1688 开放平台（gw.open.1688.com / param2 协议）
ALIBABA_OPEN_APP_KEY=your-app-key
ALIBABA_OPEN_APP_SECRET=your-app-secret
ALIBABA_OPEN_GATEWAY=https://gw.open.1688.com
ALIBABA_OPEN_REDIRECT_URI=http://localhost:3000/api/integrations/alibaba-open/callback
ALIBABA_OPEN_ACCESS_TOKEN=

# 手工 token 时补全买家登录名（也可用 npm run open1688 -- patch_meta --owner 登录名）
ALIBABA_OPEN_RESOURCE_OWNER=

# 1688 供应链询盘 Skill（DigitalHuman API，手动查结果）
# SKILL_SUPPLYCHAIN_PROCUREMENT_CLI=/path/to/1688-supplychain-api-procurement/cli.py
# ALI_1688_AK=your-clawhub-ak
# AGENT_WORK_ROOT=/path/to/agent-workspace

# FastAPI 后端（阶段 1：仅 /api/auth 与 /api/health 走代理；不设则仍用 Next API）
BACKEND_URL=http://127.0.0.1:8000
AUTH_SESSION_SECRET=tangbuy-dev-session-secret
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001

# Tangbuy Admin 订单读接口
TANGBUY_ADMIN_BASE_URL=https://admin.tangbuy.cc/prod-api
TANGBUY_ADMIN_TOKEN=your-admin-bearer-token
TANGBUY_ADMIN_STORAGE_NO=1
TANGBUY_ADMIN_EVENT_TYPE_PENDING=5888

# Tangbuy Portal 商品详情 itemGet（与 Admin Token 不同）
TANGBUY_PORTAL_BASE_URL=https://www.tangbuy.cc/gateway
TANGBUY_PORTAL_TOKEN=your-portal-bearer-token
TANGBUY_PORTAL_CURRENCY=CNY
TANGBUY_DEFAULT_SHIPPING_CITY=广东惠州市
# 入库后自动详情补全（true/false）
PRODUCT_AUTO_PIPELINE=true
# 周期扫备选（毫秒；0=关闭）
PRODUCT_AUTO_SCAN_MS=0
PRODUCT_AUTO_SCAN_ON_CREATE=false
# 备选图搜日上限；0=不限制
PRODUCT_ALT_SCAN_DAILY_LIMIT=0
PRODUCT_ALT_SCAN_BATCH_SIZE=3
